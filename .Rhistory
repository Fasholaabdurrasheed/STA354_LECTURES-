library(sn)
set.seed(123)
# compute parameters
n <- 100
n_sim <- 10000
# Compute the beta true
beta_true <- c(2, 1.2, 1.5, -0.5)
# store estimates
beta_estimate <- matrix(0, nrow = n_sim, ncol = 4)
# simulation loops
for(j in 1:n_sim){
# Computes the independent variable
x1 <- rnorm(n)
x2 <- rnorm(n)
x3 <- rnorm(n)
# compute error
error <- rexp(n, rate = 1)
# generate the dependent variable
y <- beta_true[1] + beta_true[2]*x1 + beta_true[3]*x2 + beta_true[4]*x3 + error
# fit the regression lm model
model <- lm(y ~ x1 + x2 + x3)
# store the coefficient of the estimation
beta_estimate[j, ] <- coef(model)
}
# compute the Bias
bias <- colMeans(beta_estimate)-beta_true
# MSE
mse <- colMeans((beta_estimate)-matrix(beta_true, n_sim, 4, byrow = TRUE)^2)
# RMSE
rmse <- sqrt(mse)
# Combine the result
results <- data.frame(
parameters = c("Intercept", "x1", "x2", "x3"),
True_Values = beta_true,
Bias <- bias,
MSE = mse,
RMSE = rmse,
)
# Combine the result
results <- data.frame(
parameters = c("Intercept", "x1", "x2", "x3"),
True_Value = beta_true,
Bias <- bias,
MSE = mse,
RMSE = rmse,
)
