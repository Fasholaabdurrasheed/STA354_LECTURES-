name
x = c(23,67,23,45,12,17,16)
par(mfrow = c(2,2))
plot(x)
boxplot(x)
hist(x, main="class rep")
# Test for normality
shapiro.test(x)
#parametric test
t.test(x)
# Non_Parametric test
wilcox.test(x, my = 990)
