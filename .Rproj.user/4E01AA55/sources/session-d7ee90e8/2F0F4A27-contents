## DATA STRUCTURE----
# A data structure is how data is organized and store 

# VECTOR: a vector is the simple data structure in R it is a collection 
# of values of the same data type.
scores <- c(70, 65, 80, 90)
names <- c("Ali", "Musa", "Fatimah")

# MATRIX: a matrix is a 2- dimensional data structure it has rows and columns
# must be the same data type 

mat <- matrix(c(1,2,3,4,5,6), nrow = 2, ncol = 3)

# ARRAY: an array is a multi-dimenstional matrix
arr <- array(1:12, dim = c(3,2, 2))

# DATA FRAME: very important this is the most important structure in data science
# a data frame is like an excel table 
data <- data.
